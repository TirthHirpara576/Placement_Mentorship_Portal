<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Learning Resource – TPC Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('../partials/_navbar_coord', { activePage: 'dashboard' , coordName: coordName }) %>

        <main class="section-wrapper">
            <div class="container">
                <div class="coord-form-card">

                    <h2 class="coord-form-title">📚 Add Learning Resource</h2>

                    <% if (success) { %>
                        <div class="alert-success-msg">
                            <%= success %>
                        </div>
                        <% } %>
                            <% if (error) { %>
                                <div class="alert-error-msg">
                                    <%= error %>
                                </div>
                                <% } %>

                                    <form id="addResourceForm" method="POST" action="/coordinator/add-resources"
                                        novalidate>

                                        <div class="form-group-coord">
                                            <label>Coordinator</label>
                                            <input type="text" class="coord-input" value="<%= coordName %>" readonly>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Branch <span class="req">*</span></label>
                                            <select class="coord-input" id="bid" name="bid">
                                                <option value="">-- Select Branch --</option>
                                                <% branches.forEach(b=> { %>
                                                    <option value="<%= b.bid %>">
                                                        <%= b.bname %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                            <div class="field-error" id="err_bid"></div>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Resource Link <span class="req">*</span></label>
                                            <input type="text" class="coord-input" id="rlink" name="rlink"
                                                placeholder="Enter URL here (https://...)">
                                            <div class="field-error" id="err_rlink"></div>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Details <span class="req">*</span></label>
                                            <input type="text" class="coord-input" id="Details" name="Details"
                                                placeholder="Short description of resource">
                                            <div class="field-error" id="err_details"></div>
                                        </div>

                                        <button type="submit" class="coord-submit-btn"
                                            onclick="return validateResource()">Add Resource</button>
                                        <a href="/coordinator/dashboard" class="coord-back-link">← Back to List</a>
                                    </form>
                </div>
            </div>
        </main>

        <%- include('../partials/_footer') %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                function validateResource() {
                    let valid = true;
                    document.querySelectorAll('.field-error').forEach(e => e.textContent = '');
                    document.querySelectorAll('.input-error').forEach(e => e.classList.remove('input-error'));

                    const bid = document.getElementById('bid').value;
                    if (!bid) {
                        document.getElementById('err_bid').textContent = 'Please select a branch.';
                        document.getElementById('bid').classList.add('input-error');
                        valid = false;
                    }

                    const rlink = document.getElementById('rlink').value.trim();
                    if (!rlink) {
                        document.getElementById('err_rlink').textContent = 'Resource link is required.';
                        document.getElementById('rlink').classList.add('input-error');
                        valid = false;
                    } else if (!rlink.startsWith('http://') && !rlink.startsWith('https://')) {
                        document.getElementById('err_rlink').textContent = 'Link must start with http:// or https://';
                        document.getElementById('rlink').classList.add('input-error');
                        valid = false;
                    }

                    const details = document.getElementById('Details').value.trim();
                    if (!details) {
                        document.getElementById('err_details').textContent = 'Resource description is required.';
                        document.getElementById('Details').classList.add('input-error');
                        valid = false;
                    } else if (details.length < 5) {
                        document.getElementById('err_details').textContent = 'Description must be at least 5 characters.';
                        document.getElementById('Details').classList.add('input-error');
                        valid = false;
                    }

                    return valid;
                }
            </script>
</body>

</html>