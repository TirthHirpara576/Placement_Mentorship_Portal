<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Send Mail – TPC Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('../partials/_navbar_coord', { activePage: 'dashboard' , coordName: coordName }) %>

        <main class="section-wrapper">
            <div class="container">
                <div class="coord-form-card">

                    <h2 class="coord-form-title">📧 Send Placement Mail</h2>
                    <p style="text-align:center;color:#888;font-size:0.85rem;margin-bottom:1.5rem;">
                        Notify students with important placement updates quickly and clearly
                    </p>

                    <% if (success) { %>
                        <div class="alert-success-msg">
                            <%= success %>
                        </div>
                        <% } %>
                            <% if (error) { %>
                                <div class="alert-error-msg">
                                    <%= error %>
                                </div>
                                <% } %>

                                    <form method="POST" action="/coordinator/send-mail" novalidate>

                                        <!-- Coordinator (read-only) -->
                                        <div class="form-group-coord">
                                            <label>Coordinator</label>
                                            <input type="text" class="coord-input"
                                                value="<%= coordName.replace(/^Prof\.\s*/i, '') %>" readonly>
                                        </div>

                                        <!-- Branch (read-only, from coordinator record) -->
                                        <div class="form-group-coord">
                                            <label>Branch</label>
                                            <input type="text" class="coord-input" value="<%= coordBname %>" readonly>
                                        </div>

                                        <!-- Subject -->
                                        <div class="form-group-coord">
                                            <label>Subject <span class="req">*</span></label>
                                            <input type="text" class="coord-input" id="subject" name="subject"
                                                placeholder="Placement Cell Info" maxlength="255">
                                            <div class="field-error" id="err_subject"></div>
                                        </div>

                                        <!-- Content -->
                                        <div class="form-group-coord">
                                            <label>Content <span class="req">*</span></label>
                                            <textarea class="coord-input" id="content" name="content" rows="5"
                                                placeholder="Enter your message here..."></textarea>
                                            <div class="field-error" id="err_content"></div>
                                        </div>

                                        <button type="submit" class="coord-submit-btn" onclick="return validateMail()">
                                            ✉ Send Mail to Students
                                        </button>
                                        <a href="/coordinator/dashboard" class="coord-back-link">← Back to Dashboard</a>
                                    </form>

                </div>
            </div>
        </main>

        <%- include('../partials/_footer') %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                function validateMail() {
                    let valid = true;
                    document.querySelectorAll('.field-error').forEach(e => e.textContent = '');
                    document.querySelectorAll('.input-error').forEach(e => e.classList.remove('input-error'));

                    const subject = document.getElementById('subject').value.trim();
                    if (!subject) {
                        document.getElementById('err_subject').textContent = 'Subject is required.';
                        document.getElementById('subject').classList.add('input-error');
                        valid = false;
                    }

                    const content = document.getElementById('content').value.trim();
                    if (!content) {
                        document.getElementById('err_content').textContent = 'Content / message is required.';
                        document.getElementById('content').classList.add('input-error');
                        valid = false;
                    }

                    return valid;
                }
            </script>
</body>

</html>