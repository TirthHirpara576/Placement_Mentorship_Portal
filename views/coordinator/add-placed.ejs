<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Student Placed – TPC Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('../partials/_navbar_coord', { activePage: 'dashboard' , coordName: coordName }) %>

        <main class="section-wrapper">
            <div class="container">
                <div class="coord-form-card">

                    <h2 class="coord-form-title">🎓 Add Student</h2>

                    <% if (success) { %>
                        <div class="alert-success-msg">
                            <%= success %>
                        </div>
                        <% } %>
                            <% if (error) { %>
                                <div class="alert-error-msg">
                                    <%= error %>
                                </div>
                                <% } %>

                                    <form id="addPlacedForm" method="POST" action="/coordinator/add-students-placed"
                                        novalidate>

                                        <div class="form-group-coord">
                                            <label>Coordinator</label>
                                            <input type="text" class="coord-input" value="<%= coordName %>" readonly>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Branch <span class="req">*</span></label>
                                            <select class="coord-input" id="bid" name="bid">
                                                <option value="">-- Select Branch --</option>
                                                <% branches.forEach(b=> { %>
                                                    <option value="<%= b.bid %>">
                                                        <%= b.bname %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                            <div class="field-error" id="err_bid"></div>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Year <span class="req">*</span></label>
                                            <select class="coord-input" id="yid" name="yid">
                                                <option value="">-- Select Year --</option>
                                                <% years.forEach(y=> { %>
                                                    <option value="<%= y.yid %>">
                                                        <%= y.year %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                            <div class="field-error" id="err_yid"></div>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Company <span class="req">*</span></label>
                                            <select class="coord-input" id="cid" name="cid">
                                                <option value="">-- Select Company --</option>
                                                <% companies.forEach(c=> { %>
                                                    <option value="<%= c.cid %>">
                                                        <%= c.cname %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                            <div class="field-error" id="err_cid"></div>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Student Name <span class="req">*</span></label>
                                            <input type="text" class="coord-input" id="sname" name="sname"
                                                placeholder="Enter student name">
                                            <div class="field-error" id="err_sname"></div>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Package (LPA) <span class="req">*</span></label>
                                            <input type="number" class="coord-input" id="package" name="package"
                                                placeholder="Enter package amount" step="0.01" min="0">
                                            <div class="field-error" id="err_pkg"></div>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Email / Contact <span class="req">*</span></label>
                                            <input type="text" class="coord-input" id="contact" name="contact"
                                                placeholder="Enter email">
                                            <div class="field-error" id="err_contact"></div>
                                        </div>

                                        <button type="submit" class="coord-submit-btn"
                                            onclick="return validatePlaced()">Add Student</button>
                                        <a href="/coordinator/dashboard" class="coord-back-link">← Back to List</a>
                                    </form>
                </div>
            </div>
        </main>

        <%- include('../partials/_footer') %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                function validatePlaced() {
                    let valid = true;
                    document.querySelectorAll('.field-error').forEach(e => e.textContent = '');
                    document.querySelectorAll('.input-error').forEach(e => e.classList.remove('input-error'));

                    function setErr(id, errId, msg) {
                        document.getElementById(errId).textContent = msg;
                        document.getElementById(id).classList.add('input-error');
                        valid = false;
                    }

                    if (!document.getElementById('bid').value) setErr('bid', 'err_bid', 'Please select a branch.');
                    if (!document.getElementById('yid').value) setErr('yid', 'err_yid', 'Please select a year.');
                    if (!document.getElementById('cid').value) setErr('cid', 'err_cid', 'Please select a company.');

                    const sname = document.getElementById('sname').value.trim();
                    if (!sname) setErr('sname', 'err_sname', 'Student name is required.');
                    else if (sname.length < 2) setErr('sname', 'err_sname', 'Full name is required (min 2 chars).');

                    const pkg = document.getElementById('package').value;
                    if (!pkg) setErr('package', 'err_pkg', 'Package amount is required.');
                    else if (isNaN(pkg) || parseFloat(pkg) < 0) setErr('package', 'err_pkg', 'Enter a valid positive number.');

                    const contact = document.getElementById('contact').value.trim();
                    if (!contact) setErr('contact', 'err_contact', 'Email is required.');
                    else if (contact.includes('@') && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(contact)) {
                        setErr('contact', 'err_contact', 'Enter a valid email address.');
                    }

                    return valid;
                }
            </script>
</body>

</html>