<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Company – TPC Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('../partials/_navbar_coord', { activePage: 'dashboard' , coordName: coordName }) %>

        <main class="section-wrapper">
            <div class="container">
                <div class="coord-form-card">

                    <h2 class="coord-form-title">🏢 Add Company</h2>

                    <% if (success) { %>
                        <div class="alert-success-msg">
                            <%= success %>
                        </div>
                        <% } %>
                            <% if (error) { %>
                                <div class="alert-error-msg">
                                    <%= error %>
                                </div>
                                <% } %>

                                    <form id="addCompanyForm" method="POST" action="/coordinator/add-company"
                                        enctype="multipart/form-data" novalidate>

                                        <div class="form-group-coord">
                                            <label>Coordinator</label>
                                            <input type="text" class="coord-input" value="<%= coordName %>" readonly>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Company Name <span class="req">*</span></label>
                                            <input type="text" class="coord-input" id="cname" name="cname"
                                                placeholder="Enter company name">
                                            <div class="field-error" id="err_cname"></div>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Company Logo</label>
                                            <input type="file" class="coord-input" id="logo" name="logo"
                                                accept="image/*">
                                            <div class="field-error" id="err_logo"></div>
                                        </div>

                                        <button type="submit" class="coord-submit-btn"
                                            onclick="return validateCompany()">Create Company</button>
                                        <a href="/coordinator/dashboard" class="coord-back-link">← Back to List</a>
                                    </form>
                </div>
            </div>
        </main>

        <%- include('../partials/_footer') %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                function validateCompany() {
                    let valid = true;
                    const cname = document.getElementById('cname').value.trim();
                    const errCname = document.getElementById('err_cname');

                    errCname.textContent = '';

                    if (!cname) {
                        errCname.textContent = 'Company name is required.';
                        document.getElementById('cname').classList.add('input-error');
                        valid = false;
                    } else if (cname.length < 2) {
                        errCname.textContent = 'Company name must be at least 2 characters.';
                        document.getElementById('cname').classList.add('input-error');
                        valid = false;
                    } else {
                        document.getElementById('cname').classList.remove('input-error');
                    }

                    const logoFile = document.getElementById('logo').files[0];
                    const errLogo = document.getElementById('err_logo');
                    if (logoFile) {
                        const allowed = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
                        if (!allowed.includes(logoFile.type)) {
                            errLogo.textContent = 'Logo must be an image file (jpg, png, gif, webp).';
                            valid = false;
                        } else if (logoFile.size > 2 * 1024 * 1024) {
                            errLogo.textContent = 'Logo file size must be under 2MB.';
                            valid = false;
                        }
                    }

                    return valid;
                }
            </script>
</body>

</html>