<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password – TPC Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .reset-card {
            background: #fff;
            border-radius: 18px;
            padding: 2.5rem 2rem;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.10);
            width: 100%;
            max-width: 420px;
            margin: 0 auto;
        }

        .reset-title {
            font-size: 1.5rem;
            font-weight: 800;
            color: #1a1a2e;
            text-align: center;
            margin-bottom: 1.8rem;
        }

        .reset-label {
            font-size: 0.85rem;
            font-weight: 600;
            color: #444;
            margin-bottom: 0.3rem;
            display: block;
        }

        .reset-input {
            width: 100%;
            border: 1px solid #e0e0e0;
            border-radius: 10px;
            padding: 0.65rem 1rem;
            font-size: 0.92rem;
            margin-bottom: 1.1rem;
            outline: none;
            transition: border-color 0.18s, box-shadow 0.18s;
        }

        .reset-input:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.12);
        }

        .reset-input.input-error {
            border-color: #ef4444;
        }

        .reset-submit-btn {
            width: 100%;
            background: #15803d;
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 0.7rem;
            font-weight: 700;
            font-size: 0.95rem;
            cursor: pointer;
            transition: background 0.18s;
            margin-top: 0.3rem;
        }

        .reset-submit-btn:hover {
            background: #166534;
        }

        .reset-back-link {
            display: block;
            text-align: center;
            color: #4f46e5;
            font-size: 0.85rem;
            margin-top: 1rem;
            text-decoration: none;
        }

        .reset-back-link:hover {
            text-decoration: underline;
        }

        .reset-wrapper {
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }
    </style>
</head>

<body>
    <%- include('../partials/_navbar_coord', { activePage: 'dashboard' , coordName: coordName }) %>

        <main>
            <div class="reset-wrapper">
                <div class="reset-card">

                    <h2 class="reset-title">🔑 Reset Password</h2>

                    <% if (success) { %>
                        <div class="alert-success-msg" style="margin-bottom:1.2rem;">
                            <%= success %>
                        </div>
                        <% } %>
                            <% if (error) { %>
                                <div class="alert-error-msg" style="margin-bottom:1.2rem;">
                                    <%= error %>
                                </div>
                                <% } %>

                                    <form method="POST" action="/coordinator/reset-password" novalidate>

                                        <label class="reset-label">New Password</label>
                                        <input type="password" class="reset-input" id="newPwd" name="newPwd"
                                            placeholder="Min. 6 characters" autocomplete="new-password">
                                        <div class="field-error" id="err_newPwd"></div>

                                        <label class="reset-label">Confirm Password</label>
                                        <input type="password" class="reset-input" id="confirmPwd" name="confirmPwd"
                                            placeholder="Re-enter your new password" autocomplete="new-password">
                                        <div class="field-error" id="err_confirmPwd"></div>

                                        <button type="submit" class="reset-submit-btn" onclick="return validateReset()">
                                            Update Password
                                        </button>
                                        <a href="/login" class="reset-back-link">← Back to Login</a>
                                    </form>

                </div>
            </div>
        </main>

        <%- include('../partials/_footer') %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                function validateReset() {
                    let valid = true;
                    document.querySelectorAll('.field-error').forEach(e => e.textContent = '');
                    document.querySelectorAll('.input-error').forEach(e => e.classList.remove('input-error'));

                    const newPwd = document.getElementById('newPwd').value;
                    if (!newPwd || newPwd.trim().length < 6) {
                        document.getElementById('err_newPwd').textContent = 'Password must be at least 6 characters.';
                        document.getElementById('newPwd').classList.add('input-error');
                        valid = false;
                    }

                    const confirmPwd = document.getElementById('confirmPwd').value;
                    if (newPwd && confirmPwd !== newPwd) {
                        document.getElementById('err_confirmPwd').textContent = 'Passwords do not match.';
                        document.getElementById('confirmPwd').classList.add('input-error');
                        valid = false;
                    }

                    return valid;
                }
            </script>
</body>

</html>