<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Company – TPC Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('../partials/_navbar_coord', { activePage: 'dashboard' , coordName: coordName }) %>
        <main class="section-wrapper">
            <div class="container">
                <div class="coord-form-card">
                    <h2 class="coord-form-title">✏️ Edit Company</h2>

                    <% if (success) { %>
                        <div class="alert-success-msg">
                            <%= success %>
                        </div>
                        <% } %>
                            <% if (error) { %>
                                <div class="alert-error-msg">
                                    <%= error %>
                                </div>
                                <% } %>

                                    <form method="POST" action="/coordinator/edit-company/<%= company.cid %>">
                                        <div class="form-group-coord">
                                            <label>Company Name <span class="req">*</span></label>
                                            <input type="text" class="coord-input" name="cname"
                                                value="<%= company.cname %>" placeholder="Enter company name">
                                            <div class="field-error" id="err_cname"></div>
                                        </div>
                                        <button type="submit" class="coord-submit-btn">Save Changes</button>
                                        <a href="/coordinator/profile" class="coord-back-link">← Back to Profile</a>
                                    </form>
                </div>
            </div>
        </main>
        <%- include('../partials/_footer') %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>