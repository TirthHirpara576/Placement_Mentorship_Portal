<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Scheduled Sessions – TPC Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .sessions-card {
            background: #fff;
            border-radius: 14px;
            padding: 1.8rem;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
            margin: 2rem auto;
            max-width: 960px;
        }

        .sessions-title {
            text-align: center;
            font-size: 1.6rem;
            font-weight: 800;
            color: #1a1a2e;
            margin-bottom: 0.3rem;
        }

        .sessions-subtitle {
            text-align: center;
            font-size: 0.88rem;
            color: #888;
            margin-bottom: 1.5rem;
        }

        .sessions-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.88rem;
        }

        .sessions-table thead tr {
            background: #f0f4ff;
        }

        .sessions-table th {
            padding: 0.65rem 1rem;
            font-weight: 700;
            color: #555;
            text-align: left;
            border-bottom: 2px solid #e5e7eb;
            font-size: 0.82rem;
        }

        .sessions-table td {
            padding: 0.7rem 1rem;
            border-bottom: 1px solid #f3f4f6;
            vertical-align: middle;
            color: #333;
        }

        .sessions-table tr:last-child td {
            border-bottom: none;
        }

        .sessions-table tr:hover td {
            background: #fafafa;
        }

        .btn-open-link {
            background: #0ea5e9;
            color: #fff;
            border: none;
            border-radius: 6px;
            padding: 0.3rem 0.75rem;
            font-size: 0.78rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            transition: background 0.18s;
        }

        .btn-open-link:hover {
            background: #0284c7;
            color: #fff;
            text-decoration: none;
        }

        .branch-pill {
            display: inline-block;
            background: #0ea5e9;
            color: #fff;
            border-radius: 6px;
            padding: 0.18rem 0.6rem;
            font-size: 0.75rem;
            font-weight: 700;
            white-space: nowrap;
        }

        .no-link-text {
            color: #bbb;
            font-size: 0.8rem;
            font-style: italic;
        }

        .add-btn-row {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 1.2rem;
        }

        .btn-add-session {
            background: #4f46e5;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 0.45rem 1.2rem;
            font-size: 0.85rem;
            font-weight: 700;
            text-decoration: none;
            transition: background 0.18s;
        }

        .btn-add-session:hover {
            background: #4338ca;
            color: #fff;
            text-decoration: none;
        }
    </style>
</head>

<body>
    <%- include('../partials/_navbar_coord', { activePage: 'dashboard' , coordName: coordName }) %>

        <main class="section-wrapper">
            <div class="container">
                <div class="sessions-card">

                    <h2 class="sessions-title">📅 Scheduled Sessions</h2>
                    <p class="sessions-subtitle">All sessions arranged by coordinators</p>

                    <div class="add-btn-row">
                        <a href="/coordinator/add-session" class="btn-add-session">+ Add New Session</a>
                    </div>

                    <% if (sessions.length===0) { %>
                        <div style="text-align:center;color:#aaa;padding:2rem;font-size:0.95rem;">
                            No sessions added yet. Click <strong>"+ Add New Session"</strong> to get started.
                        </div>
                        <% } else { %>
                            <div style="overflow-x:auto;">
                                <table class="sessions-table">
                                    <thead>
                                        <tr>
                                            <th>🔗 Link</th>
                                            <th>📋 Detail</th>
                                            <th>⏰ Time</th>
                                            <th>🏷 Branch</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% sessions.forEach(s=> { %>
                                            <tr>
                                                <td>
                                                    <% if (s.link) { %>
                                                        <a href="<%= s.link %>" target="_blank"
                                                            class="btn-open-link">Open Link</a>
                                                        <% } else { %>
                                                            <span class="no-link-text">No link</span>
                                                            <% } %>
                                                </td>
                                                <td>
                                                    <%= s.detail %>
                                                </td>
                                                <td>
                                                    <%= s.time %>
                                                </td>
                                                <td>
                                                    <span class="branch-pill">
                                                        <%= s.bname %>
                                                    </span>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                            <% } %>

                </div>
            </div>
        </main>

        <%- include('../partials/_footer') %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>