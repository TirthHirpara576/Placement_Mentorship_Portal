<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Session – TPC Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('../partials/_navbar_coord', { activePage: 'dashboard' , coordName: coordName }) %>
        <main class="section-wrapper">
            <div class="container">
                <div class="coord-form-card">
                    <h2 class="coord-form-title">✏️ Edit Session</h2>

                    <% if (success) { %>
                        <div class="alert-success-msg">
                            <%= success %>
                        </div>
                        <% } %>
                            <% if (error) { %>
                                <div class="alert-error-msg">
                                    <%= error %>
                                </div>
                                <% } %>

                                    <form method="POST" action="/coordinator/edit-session/<%= record.id %>" novalidate>

                                        <div class="form-group-coord">
                                            <label>Branch <span class="req">*</span></label>
                                            <select class="coord-input" id="bid" name="bid">
                                                <option value="">-- Select Branch --</option>
                                                <% branches.forEach(b=> { %>
                                                    <option value="<%= b.bid %>" <%=record.bid==b.bid ? 'selected' : ''
                                                        %>><%= b.bname %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                            <div class="field-error" id="err_bid"></div>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Description About Session <span class="req">*</span></label>
                                            <textarea class="coord-input" id="detail" name="detail" rows="3"
                                                placeholder="Enter session details..."><%= record.detail %></textarea>
                                            <div class="field-error" id="err_detail"></div>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Time <span class="req">*</span></label>
                                            <input type="text" class="coord-input" id="time" name="time"
                                                value="<%= record.time %>" placeholder="e.g. 23 Jan, 2026; 10 AM">
                                            <div class="field-error" id="err_time"></div>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Session Link <span
                                                    style="color:#aaa;font-size:0.8rem;">(optional)</span></label>
                                            <input type="text" class="coord-input" id="link" name="link"
                                                value="<%= record.link || '' %>"
                                                placeholder="https://meet.google.com/...">
                                        </div>

                                        <button type="submit" class="coord-submit-btn"
                                            onclick="return validateSession()">Save Changes</button>
                                        <a href="/coordinator/profile" class="coord-back-link">← Back to Profile</a>
                                    </form>
                </div>
            </div>
        </main>
        <%- include('../partials/_footer') %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                function validateSession() {
                    let valid = true;
                    document.querySelectorAll('.field-error').forEach(e => e.textContent = '');
                    document.querySelectorAll('.input-error').forEach(e => e.classList.remove('input-error'));
                    const bid = document.getElementById('bid').value;
                    if (!bid) {
                        document.getElementById('err_bid').textContent = 'Please select a branch.';
                        document.getElementById('bid').classList.add('input-error'); valid = false;
                    }
                    const detail = document.getElementById('detail').value.trim();
                    if (!detail) {
                        document.getElementById('err_detail').textContent = 'Session description is required.';
                        document.getElementById('detail').classList.add('input-error'); valid = false;
                    }
                    const time = document.getElementById('time').value.trim();
                    if (!time) {
                        document.getElementById('err_time').textContent = 'Session time is required.';
                        document.getElementById('time').classList.add('input-error'); valid = false;
                    }
                    return valid;
                }
            </script>
</body>

</html>