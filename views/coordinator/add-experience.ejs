<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Company Experience – TPC Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('../partials/_navbar_coord', { activePage: 'dashboard' , coordName: coordName }) %>

        <main class="section-wrapper">
            <div class="container">
                <div class="coord-form-card">

                    <h2 class="coord-form-title">📝 Add Company Experience</h2>

                    <% if (success) { %>
                        <div class="alert-success-msg">
                            <%= success %>
                        </div>
                        <% } %>
                            <% if (error) { %>
                                <div class="alert-error-msg">
                                    <%= error %>
                                </div>
                                <% } %>

                                    <form id="addExpForm" method="POST" action="/coordinator/add-student-experiences"
                                        novalidate>

                                        <div class="form-group-coord">
                                            <label>Coordinator</label>
                                            <input type="text" class="coord-input" value="<%= coordName %>" readonly>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Company <span class="req">*</span></label>
                                            <select class="coord-input" id="cid" name="cid">
                                                <option value="">-- Select Company --</option>
                                                <% companies.forEach(c=> { %>
                                                    <option value="<%= c.cid %>">
                                                        <%= c.cname %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                            <div class="field-error" id="err_cid"></div>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Experience <span class="req">*</span></label>
                                            <textarea class="coord-input" id="dtext" name="dtext" rows="5"
                                                placeholder="Describe the company interview experience, tips, process..."></textarea>
                                            <div class="field-error" id="err_dtext"></div>
                                        </div>

                                        <button type="submit" class="coord-submit-btn"
                                            onclick="return validateExp()">Create Description</button>
                                        <a href="/coordinator/dashboard" class="coord-back-link">← Back to List</a>
                                    </form>
                </div>
            </div>
        </main>

        <%- include('../partials/_footer') %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                function validateExp() {
                    let valid = true;
                    document.querySelectorAll('.field-error').forEach(e => e.textContent = '');
                    document.querySelectorAll('.input-error').forEach(e => e.classList.remove('input-error'));

                    const cid = document.getElementById('cid').value;
                    if (!cid) {
                        document.getElementById('err_cid').textContent = 'Please select a company.';
                        document.getElementById('cid').classList.add('input-error');
                        valid = false;
                    }

                    const dtext = document.getElementById('dtext').value.trim();
                    if (!dtext) {
                        document.getElementById('err_dtext').textContent = 'Experience description is required.';
                        document.getElementById('dtext').classList.add('input-error');
                        valid = false;
                    } else if (dtext.length < 10) {
                        document.getElementById('err_dtext').textContent = 'Please enter at least 10 characters.';
                        document.getElementById('dtext').classList.add('input-error');
                        valid = false;
                    }

                    return valid;
                }
            </script>
</body>

</html>