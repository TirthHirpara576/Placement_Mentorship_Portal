<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Student Placed – TPC Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('../partials/_navbar_coord', { activePage: 'dashboard' , coordName: coordName }) %>
        <main class="section-wrapper">
            <div class="container">
                <div class="coord-form-card">
                    <h2 class="coord-form-title">✏️ Edit Student Placed</h2>

                    <% if (success) { %>
                        <div class="alert-success-msg">
                            <%= success %>
                        </div>
                        <% } %>
                            <% if (error) { %>
                                <div class="alert-error-msg">
                                    <%= error %>
                                </div>
                                <% } %>

                                    <form method="POST" action="/coordinator/edit-placed/<%= record.id %>" novalidate>

                                        <div class="form-group-coord">
                                            <label>Student Name <span class="req">*</span></label>
                                            <input type="text" class="coord-input" id="sname" name="sname"
                                                value="<%= record.sname %>" placeholder="Full Name">
                                            <div class="field-error" id="err_sname"></div>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Company <span class="req">*</span></label>
                                            <select class="coord-input" id="cid" name="cid">
                                                <option value="">-- Select Company --</option>
                                                <% companies.forEach(c=> { %>
                                                    <option value="<%= c.cid %>" <%=record.cid==c.cid ? 'selected' : ''
                                                        %>><%= c.cname %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                            <div class="field-error" id="err_cid"></div>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Branch <span class="req">*</span></label>
                                            <select class="coord-input" id="bid" name="bid">
                                                <option value="">-- Select Branch --</option>
                                                <% branches.forEach(b=> { %>
                                                    <option value="<%= b.bid %>" <%=record.bid==b.bid ? 'selected' : ''
                                                        %>><%= b.bname %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                            <div class="field-error" id="err_bid"></div>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Year <span class="req">*</span></label>
                                            <select class="coord-input" id="yid" name="yid">
                                                <option value="">-- Select Year --</option>
                                                <% years.forEach(y=> { %>
                                                    <option value="<%= y.yid %>" <%=record.yid==y.yid ? 'selected' : ''
                                                        %>><%= y.year %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                            <div class="field-error" id="err_yid"></div>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Package (LPA) <span class="req">*</span></label>
                                            <input type="number" step="0.01" class="coord-input" id="package"
                                                name="package" value="<%= record.package %>" placeholder="e.g. 15.5">
                                            <div class="field-error" id="err_pkg"></div>
                                        </div>

                                        <div class="form-group-coord">
                                            <label>Contact / Email <span class="req">*</span></label>
                                            <input type="text" class="coord-input" id="contact" name="contact"
                                                value="<%= record.contact %>" placeholder="student@email.com">
                                            <div class="field-error" id="err_contact"></div>
                                        </div>

                                        <button type="submit" class="coord-submit-btn"
                                            onclick="return validatePlaced()">Save Changes</button>
                                        <a href="/coordinator/profile" class="coord-back-link">← Back to Profile</a>
                                    </form>
                </div>
            </div>
        </main>
        <%- include('../partials/_footer') %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                function validatePlaced() {
                    let valid = true;
                    document.querySelectorAll('.field-error').forEach(e => e.textContent = '');
                    document.querySelectorAll('.input-error').forEach(e => e.classList.remove('input-error'));
                    const fields = [
                        { id: 'sname', errId: 'err_sname', msg: 'Student name is required.' },
                        { id: 'cid', errId: 'err_cid', msg: 'Please select a company.' },
                        { id: 'bid', errId: 'err_bid', msg: 'Please select a branch.' },
                        { id: 'yid', errId: 'err_yid', msg: 'Please select a year.' },
                        { id: 'package', errId: 'err_pkg', msg: 'Package (LPA) is required.' },
                        { id: 'contact', errId: 'err_contact', msg: 'Contact/email is required.' },
                    ];
                    fields.forEach(f => {
                        const el = document.getElementById(f.id);
                        if (!el.value || !el.value.trim()) {
                            document.getElementById(f.errId).textContent = f.msg;
                            el.classList.add('input-error');
                            valid = false;
                        }
                    });
                    return valid;
                }
            </script>
</body>

</html>