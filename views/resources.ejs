<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Resources – Placement Mentorship Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <% if (typeof isAdmin !=='undefined' && isAdmin) { %>
        <%- include('partials/_navbar_admin', { activePage: activePage, adminName: adminName }) %>
            <% } else if (typeof isCoordinator !=='undefined' && isCoordinator) { %>
                <%- include('partials/_navbar_coord', { activePage: activePage, coordName: coordName }) %>
                    <% } else { %>
                        <%- include('partials/_navbar') %>
                            <% } %>

                                <main class="section-wrapper">
                                    <div class="container">
                                        <h1 class="page-title">Resources</h1>

                                        <!-- Filter Card -->
                                        <form method="GET" action="/Home/Resources">
                                            <div class="filter-card">
                                                <div class="row g-3 align-items-end">
                                                    <div class="col-md-6">
                                                        <label>Select Branch</label>
                                                        <select name="bid" class="form-select">
                                                            <option value="">All Branches</option>
                                                            <% branches.forEach(b=> { %>
                                                                <option value="<%= b.bid %>" <%=selectedBid==b.bid
                                                                    ? 'selected' : '' %>>
                                                                    <%= b.bname %>
                                                                </option>
                                                                <% }) %>
                                                        </select>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label>&nbsp;</label>
                                                        <button type="submit" class="btn-filter">Apply Filter</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </form>

                                        <!-- Resources Grid -->
                                        <% if (resources.length===0) { %>
                                            <div class="no-data">No resources found for the selected branch.</div>
                                            <% } else { %>
                                                <div class="row g-3">
                                                    <% resources.forEach(r=> { %>
                                                        <div class="col-md-4">
                                                            <div class="resource-card">
                                                                <% if (r.bname) { %>
                                                                    <span class="resource-badge">
                                                                        <%= r.bname %>
                                                                    </span>
                                                                    <% } %>
                                                                        <div class="resource-detail">
                                                                            <%= r["Details"] || r.details %>
                                                                        </div>
                                                                        <a href="<%= r.rlink %>" target="_blank"
                                                                            class="btn-open-resource">Open
                                                                            Resource</a>
                                                            </div>
                                                        </div>
                                                        <% }) %>
                                                </div>
                                                <% } %>
                                    </div>
                                </main>

                                <%- include('partials/_footer') %>

                                    <script
                                        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>