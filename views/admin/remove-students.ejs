<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Remove Students – Admin Panel</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <%- include('../partials/_navbar_admin', { activePage: 'dashboard' , adminName: adminName }) %>

        <main class="section-wrapper">
            <div class="container">
                <div>

                    <h3 class="coord-form-title text-start text-dark mb-1">Remove Students</h3>

                    <% if (success) { %>
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            ✅ <%= success %>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                        <% } %>
                            <% if (error) { %>
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    ⚠️ <%= error %>
                                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                </div>
                                <% } %>

                                    <p class="text-muted" style="font-size: 0.88rem; margin-bottom: 2rem;">
                                        <span style="color: #b45309;">⚠️</span> Once you select a year and submit,
                                        <strong>all students</strong> from that year will be permanently removed from
                                        the database. This action cannot be undone.
                                    </p>

                                    <form method="POST" action="/admin/remove-students">
                                        <div class="mb-3" style="max-width: 800px;">
                                            <label class="form-label" style="font-size: 0.85rem; color: #555;">Select
                                                Year</label>
                                            <select name="year" class="form-select bg-light border-0" required>
                                                <option value="All">All</option>
                                                <% years.forEach(y=> { %>
                                                    <option value="<%= y %>">
                                                        <%= y %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                        </div>

                                        <div class="d-flex gap-3 mt-3">
                                            <button type="submit" class="btn"
                                                style="background: #991b1b; color: #fff; font-size: 0.88rem; padding: 0.4rem 1.2rem; border-radius: 4px;">
                                                Delete Students
                                            </button>
                                            <a href="/admin/dashboard" class="btn text-muted"
                                                style="font-size: 0.88rem; padding: 0.4rem 1.2rem;">
                                                Cancel
                                            </a>
                                        </div>
                                    </form>

                </div>
            </div>
        </main>

        <%- include('../partials/_footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>