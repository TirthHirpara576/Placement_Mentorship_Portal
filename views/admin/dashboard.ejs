<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard – Placement Mentorship Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <%- include('../partials/_navbar_admin', { activePage: 'dashboard' , adminName: adminName }) %>

        <main class="section-wrapper"
            style="padding-top: 3rem; background: linear-gradient(180deg, #e0f2fe 0%, #f8fafc 100%); min-height: calc(100vh - 140px);">
            <div class="container" style="max-width: 800px;">

                <!-- Hero Title -->
                <div class="text-center mb-4">
                    <h2 style="font-weight: 600; color: #1e293b; letter-spacing: -0.5px;">Admin Dashboard</h2>
                </div>

                <!-- Accordions -->
                <div class="accordion" id="adminAccordion">

                    <!-- Branches Added -->
                    <div class="accordion-item shadow-sm mb-3"
                        style="border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden;">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                                data-bs-target="#collapseOne"
                                style="background: #ffffff; color: #334155; font-weight: 500;">
                                Branches Added
                            </button>
                        </h2>
                        <div id="collapseOne" class="accordion-collapse collapse" data-bs-parent="#adminAccordion">
                            <div class="accordion-body bg-light" style="padding: 1rem;">
                                <div class="d-flex flex-column gap-2">
                                    <% if (branches.length===0) { %>
                                        <div class="text-muted" style="font-size:0.9rem;">No branches added.</div>
                                        <% } else { %>
                                            <% branches.forEach(b=> { %>
                                                <div
                                                    class="d-flex justify-content-between align-items-center bg-transparent border-bottom pb-2">
                                                    <span style="font-size:0.85rem; font-weight: 600; color: #1e293b;">
                                                        <%= b.bname %>
                                                    </span>
                                                    <button class="btn btn-sm"
                                                        style="background:#2f3b9c; color:white; border-radius:12px; font-size:0.7rem; padding:0.15rem 0.6rem;"
                                                        onclick="openUpdate('branch', '<%= b.bid %>', '<%= b.bname %>', '')">Update</button>
                                                </div>
                                                <% }) %>
                                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Years Added -->
                    <div class="accordion-item shadow-sm mb-3"
                        style="border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden;">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                                data-bs-target="#collapseTwo"
                                style="background: #ffffff; color: #334155; font-weight: 500;">
                                Years Added
                            </button>
                        </h2>
                        <div id="collapseTwo" class="accordion-collapse collapse" data-bs-parent="#adminAccordion">
                            <div class="accordion-body bg-light" style="padding: 1rem;">
                                <div class="d-flex flex-column gap-2">
                                    <% if (years.length===0) { %>
                                        <div class="text-muted" style="font-size:0.9rem;">No years added.</div>
                                        <% } else { %>
                                            <% years.forEach(y=> { %>
                                                <div
                                                    class="d-flex justify-content-between align-items-center bg-transparent border-bottom pb-2">
                                                    <span style="font-size:0.85rem; font-weight: 600; color: #1e293b;">
                                                        <%= y.year %>
                                                    </span>
                                                    <button class="btn btn-sm"
                                                        style="background:#2f3b9c; color:white; border-radius:12px; font-size:0.7rem; padding:0.15rem 0.6rem;"
                                                        onclick="openUpdate('year', '<%= y.yid %>', '<%= y.year %>', '')">Update</button>
                                                </div>
                                                <% }) %>
                                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Active Coordinators -->
                    <div class="accordion-item shadow-sm mb-3"
                        style="border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden;">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                                data-bs-target="#collapseThree"
                                style="background: #ffffff; color: #334155; font-weight: 500;">
                                Active Coordinators
                            </button>
                        </h2>
                        <div id="collapseThree" class="accordion-collapse collapse" data-bs-parent="#adminAccordion">
                            <div class="accordion-body bg-light" style="padding: 1rem;">
                                <div class="d-flex flex-column gap-2">
                                    <% if (coordinators.length===0) { %>
                                        <div class="text-muted" style="font-size:0.9rem;">No active coordinators.</div>
                                        <% } else { %>
                                            <% coordinators.forEach(c=> { %>
                                                <div
                                                    class="d-flex justify-content-between align-items-center bg-transparent border-bottom pb-2">
                                                    <span style="font-size:0.85rem; font-weight: 600; color: #1e293b;">
                                                        <%= c.tname %> (<%= c.bname || 'No Branch' %>) | <span
                                                                    class="text-muted fw-normal">✉ <%= c.contact %>
                                                                </span>
                                                    </span>
                                                    <button class="btn btn-sm"
                                                        style="background:#2f3b9c; color:white; border-radius:12px; font-size:0.7rem; padding:0.15rem 0.6rem;"
                                                        onclick="openUpdate('coordinator', '<%= c.tid %>', '<%= c.tname %>', '<%= c.contact %>')">Update</button>
                                                </div>
                                                <% }) %>
                                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Branch Intake Summary -->
                    <div class="accordion-item shadow-sm mb-4"
                        style="border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden;">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                                data-bs-target="#collapseFour"
                                style="background: #ffffff; color: #334155; font-weight: 500;">
                                Branch Intake Summary
                            </button>
                        </h2>
                        <div id="collapseFour" class="accordion-collapse collapse" data-bs-parent="#adminAccordion">
                            <div class="accordion-body bg-light" style="padding: 1rem;">
                                <% const uniqueYears=[...new Set(intake.map(i=> i.year))].sort((a,b)=>b-a); %>
                                    <div class="mb-3 d-flex align-items-center gap-2">
                                        <label style="font-size: 0.8rem; color: #334155;">Filter Year:</label>
                                        <select id="intakeFilter" class="form-select border-0 bg-white shadow-sm"
                                            style="width: 100px; font-size:0.8rem;" onchange="filterIntake()">
                                            <% uniqueYears.forEach(y=> { %>
                                                <option value="<%= y %>">
                                                    <%= y %>
                                                </option>
                                                <% }) %>
                                        </select>
                                    </div>

                                    <div class="d-flex flex-column gap-2 mb-3">
                                        <% if (intake.length===0) { %>
                                            <div class="text-muted" style="font-size:0.9rem;">No intake summaries.</div>
                                            <% } else { %>
                                                <% intake.forEach(i=> { %>
                                                    <div class="intake-item d-flex justify-content-between align-items-center bg-transparent border-bottom pb-2"
                                                        data-year="<%= i.year %>">
                                                        <span
                                                            style="font-size:0.85rem; font-weight: 600; color: #1e293b;">
                                                            <%= i.bname %>: <span class="fw-normal text-muted">
                                                                    <%= i.count %> Students
                                                                </span>
                                                        </span>
                                                        <button class="btn btn-sm"
                                                            style="background:#2f3b9c; color:white; border-radius:12px; font-size:0.7rem; padding:0.15rem 0.6rem;"
                                                            onclick="openUpdate('intake', '<%= i.id %>', '<%= i.count %>', '')">Update</button>
                                                    </div>
                                                    <% }) %>
                                                        <% } %>
                                    </div>

                                    <div>
                                        <a href="/admin/add-student-count" class="btn btn-sm border"
                                            style="font-size:0.75rem; color:#475569; background:#fff;">+ Add New
                                            Intake</a>
                                    </div>
                            </div>
                        </div>
                    </div>

                </div>



                <!-- Dynamic Update Modal -->
                <div class="modal fade" id="updateModal" tabindex="-1" aria-labelledby="updateModalLabel"
                    aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <form class="modal-content border-0 shadow" method="POST" action="/admin/dashboard-update">
                            <div class="modal-header border-bottom-0 pb-0">
                                <h5 class="modal-title fw-bold" id="updateModalLabel" style="color:#1e293b;">Update
                                    Record</h5>
                                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"
                                    aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <input type="hidden" name="updateType" id="updateType">
                                <input type="hidden" name="updateId" id="updateId">
                                <div id="updateModalBody"></div>
                            </div>
                            <div class="modal-footer border-top-0 pt-0">
                                <button type="button" class="btn text-muted bg-light border-0 shadow-none"
                                    data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn" style="background:#2f3b9c; color:white;">Save
                                    Changes</button>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </main>

        <%- include('../partials/_footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                function openUpdate(type, id, val1, val2) {
                    document.getElementById('updateType').value = type;
                    document.getElementById('updateId').value = id;
                    const body = document.getElementById('updateModalBody');
                    const title = document.getElementById('updateModalLabel');

                    if (type === 'branch') {
                        title.innerText = 'Update Branch';
                        body.innerHTML = '<div class="mb-3"><label class="form-label text-muted fs-6">Branch Name</label><input type="text" name="bname" class="form-control" value="' + val1 + '" required></div>';
                    } else if (type === 'year') {
                        title.innerText = 'Update Year';
                        body.innerHTML = '<div class="mb-3"><label class="form-label text-muted fs-6">Year</label><input type="number" name="year" class="form-control" value="' + val1 + '" required></div>';
                    } else if (type === 'coordinator') {
                        title.innerText = 'Update Coordinator';
                        body.innerHTML = '<div class="mb-3"><label class="form-label text-muted fs-6">Name</label><input type="text" name="tname" class="form-control" value="' + val1 + '" required></div><div class="mb-3"><label class="form-label text-muted fs-6">Email</label><input type="text" name="contact" class="form-control" value="' + val2 + '" required></div>';
                    } else if (type === 'intake') {
                        title.innerText = 'Update Student Intake Count';
                        body.innerHTML = '<div class="mb-3"><label class="form-label text-muted fs-6">Student Count</label><input type="number" name="count" class="form-control" value="' + val1 + '" required></div>';
                    }

                    new bootstrap.Modal(document.getElementById('updateModal')).show();
                }

                function filterIntake() {
                    const select = document.getElementById('intakeFilter');
                    if (!select) return;
                    const year = select.value;
                    document.querySelectorAll('.intake-item').forEach(item => {
                        if (item.dataset.year === year || year === 'all') {
                            item.classList.remove('d-none');
                            item.classList.add('d-flex');
                        } else {
                            item.classList.remove('d-flex');
                            item.classList.add('d-none');
                        }
                    });
                }

                document.addEventListener('DOMContentLoaded', filterIntake);
            </script>
</body>

</html>