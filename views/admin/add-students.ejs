<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Students – Admin Panel</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <%- include('../partials/_navbar_admin', { activePage: 'dashboard' , adminName: adminName }) %>

        <main class="section-wrapper">
            <div class="container">
                <div class="coord-form-card">

                    <h3 class="coord-form-title">📥 Add Students (Bulk)</h3>

                    <% if (success) { %>
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            ✅ <%= success %>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                        <% } %>
                            <% if (error) { %>
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    ⚠️ <%= error %>
                                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                </div>
                                <% } %>

                                    <form method="POST" action="/admin/add-students" enctype="multipart/form-data">
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">Excel file (.xlsx or .xls) — columns:
                                                Mail | Bname | Entryyear</label>
                                            <input type="file" name="file" class="form-control" accept=".xlsx, .xls"
                                                required>
                                        </div>
                                        <button type="submit" class="coord-submit-btn"
                                            style="background: #0d47a1; border-radius: 8px;">📤 Upload and
                                            Import</button>
                                        <div class="form-text text-muted mt-3" style="font-size: 0.82rem;">
                                            If the first row is a header (Mail, Bname, Entryyear), it will be ignored
                                            automatically.
                                        </div>
                                    </form>

                                    <div class="text-center mt-3">
                                        <a href="/admin/dashboard" class="coord-back-link text-muted"
                                            style="text-decoration:none;">← Go To Index Page</a>
                                    </div>

                </div>
            </div>
        </main>

        <%- include('../partials/_footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>