<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Branch – Admin Panel</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <%- include('../partials/_navbar_admin', { activePage: 'dashboard' , adminName: adminName }) %>

        <main class="section-wrapper">
            <div class="container">
                <div class="coord-form-card">

                    <h3 class="coord-form-title">🌿 Add Branch</h3>

                    <% if (success) { %>
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            ✅ <%= success %>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                        <% } %>
                            <% if (error) { %>
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    ⚠️ <%= error %>
                                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                </div>
                                <% } %>

                                    <form method="POST" action="/admin/add-branch" novalidate>
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">Branch Name</label>
                                            <input type="text" name="bname" class="form-control"
                                                placeholder="Enter branch name" required>
                                            <div class="form-text text-muted">e.g. CP, IT, MF, CE</div>
                                        </div>
                                        <button type="submit" class="coord-submit-btn"
                                            style="background: #0d47a1; border-radius: 8px;">Add Branch</button>
                                    </form>

                                    <div class="text-center mt-3">
                                        <a href="/admin/dashboard" class="coord-back-link text-muted"
                                            style="text-decoration:none;">← Back to List</a>
                                    </div>

                                    <!-- Existing Branches -->
                                    <% if (branches && branches.length> 0) { %>
                                        <div class="mt-4">
                                            <h6 class="fw-bold text-secondary mb-2">Existing Branches</h6>
                                            <div class="d-flex flex-wrap gap-2">
                                                <% branches.forEach(b=> { %>
                                                    <span class="badge-year" style="background:#ede9fe;color:#7c3aed;">
                                                        <%= b.bname %>
                                                    </span>
                                                    <% }) %>
                                            </div>
                                        </div>
                                        <% } %>

                </div>
            </div>
        </main>

        <%- include('../partials/_footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>