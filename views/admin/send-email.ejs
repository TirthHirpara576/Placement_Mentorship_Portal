<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Send Email – Admin Panel</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <%- include('../partials/_navbar_admin', { activePage: 'dashboard' , adminName: adminName }) %>

        <main class="section-wrapper">
            <div class="container">
                <div class="coord-form-card">

                    <h3 class="coord-form-title">📧 Send Placement Mail</h3>
                    <p class="text-center text-muted" style="font-size: 0.88rem; margin-bottom: 2rem;">Notify students
                        with important placement updates quickly and clearly</p>

                    <% if (success) { %>
                        <div
                            style="background: #e6eed8; border: 1px solid #c9d8b7; border-radius: 6px; padding: 10px; text-align: center; color: #333; margin-bottom: 1.5rem; font-size: 0.9rem;">
                            <%= success %>
                        </div>
                        <% } %>
                            <% if (error) { %>
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    ⚠️ <%= error %>
                                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                </div>
                                <% } %>

                                    <form method="POST" action="/admin/send-email" enctype="multipart/form-data">

                                        <div class="mb-3">
                                            <label class="form-label fw-semibold"
                                                style="font-size: 0.85rem;">Coordinator</label>
                                            <input type="text" class="form-control bg-light text-muted"
                                                value="<%= adminName || 'System Administrator' %>" readonly>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label fw-semibold"
                                                style="font-size: 0.85rem;">Branch</label>
                                            <select name="bid" class="form-select" required>
                                                <option value="">-- Select Branch --</option>
                                                <% branches.forEach(b=> { %>
                                                    <option value="<%= b.bid %>">
                                                        <%= b.bname %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold"
                                                style="font-size: 0.85rem;">Subject</label>
                                            <input type="text" name="subject" class="form-control"
                                                placeholder="Enter mail subject..." required>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold"
                                                style="font-size: 0.85rem;">Content</label>
                                            <textarea name="content" class="form-control" rows="5"
                                                placeholder="Write your placement message here..." required></textarea>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold"
                                                style="font-size: 0.85rem;">Attachments (optional)</label>
                                            <input type="file" name="attachment" class="form-control">
                                        </div>
                                        <button type="submit" class="coord-submit-btn"
                                            style="background: #0d47a1; border-radius: 8px;">🚀 Send Mail to
                                            Students</button>
                                    </form>

                                    <div class="text-center mt-3">
                                        <a href="/admin/dashboard" class="coord-back-link text-muted"
                                            style="text-decoration:none;">← Back to Dashboard</a>
                                    </div>

                </div>
            </div>
        </main>

        <%- include('../partials/_footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>