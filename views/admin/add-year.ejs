<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Year – Admin Panel</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <%- include('../partials/_navbar_admin', { activePage: 'dashboard' , adminName: adminName }) %>

        <main class="section-wrapper">
            <div class="container">
                <div class="coord-form-card">

                    <h3 class="coord-form-title">&#128197; Add Year</h3>

                    <!-- Welcome strip info -->
                    <div
                        style="background: #e6eed8; border: 1px solid #c9d8b7; border-radius: 6px; padding: 10px; text-align: center; color: #333; margin-bottom: 1.5rem; font-weight: 500;">
                        Welcome, Prof. Mehul Patel
                    </div>

                    <% if (success) { %>
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            ✅ <%= success %>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                        <% } %>
                            <% if (error) { %>
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    ⚠️ <%= error %>
                                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                </div>
                                <% } %>

                                    <form method="POST" action="/admin/add-year" novalidate>
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">Year</label>
                                            <input type="number" name="year" class="form-control"
                                                placeholder="Enter year" min="1900" max="2100" required>
                                        </div>
                                        <button type="submit" class="coord-submit-btn"
                                            style="background: #0d47a1; border-radius: 8px;">+ Add Year</button>
                                    </form>

                                    <div class="text-center mt-3">
                                        <a href="/admin/dashboard" class="coord-back-link text-muted"
                                            style="text-decoration:none;">← Back to List</a>
                                    </div>

                                    <!-- Existing Years -->
                                    <% if (years && years.length> 0) { %>
                                        <div class="mt-4">
                                            <h6 class="fw-bold text-secondary mb-2">Existing Years</h6>
                                            <div class="d-flex flex-wrap gap-2">
                                                <% years.forEach(y=> { %>
                                                    <span class="badge-year">
                                                        <%= y.year %>
                                                    </span>
                                                    <% }) %>
                                            </div>
                                        </div>
                                        <% } %>

                </div>
            </div>
        </main>

        <%- include('../partials/_footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>