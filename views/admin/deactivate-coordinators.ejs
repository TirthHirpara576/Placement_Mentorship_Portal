<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Deactivate Coordinators – Admin Panel</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <%- include('../partials/_navbar_admin', { activePage: 'dashboard' , adminName: adminName }) %>

        <main class="section-wrapper">
            <div class="container">
                <div class="coord-form-card" style="max-width: 680px;">

                    <h3 class="coord-form-title">⚠️ Deactivate Coordinators</h3>

                    <% if (success) { %>
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            ✅ <%= success %>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                        <% } %>
                            <% if (error) { %>
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    ⚠️ <%= error %>
                                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                </div>
                                <% } %>

                                    <% if (coordinators.length===0) { %>
                                        <p class="text-center text-muted py-4">No active coordinators found.</p>
                                        <% } else { %>
                                            <form method="POST" action="/admin/deactivate-coordinators">
                                                <div class="table-responsive">
                                                    <table class="reg-table">
                                                        <thead>
                                                            <tr>
                                                                <th style="width: 50px;">Select</th>
                                                                <th>Name</th>
                                                                <th>Branch</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <% coordinators.forEach(coord=> { %>
                                                                <tr>
                                                                    <td>
                                                                        <input type="checkbox" name="selected"
                                                                            value="<%= coord.tid %>"
                                                                            class="form-check-input"
                                                                            style="width:18px;height:18px;">
                                                                    </td>
                                                                    <td><strong>
                                                                            <%= coord.tname %>
                                                                        </strong></td>
                                                                    <td><span class="badge-year"
                                                                            style="background:#ede9fe;color:#7c3aed;">
                                                                            <%= coord.bname || '—' %>
                                                                        </span></td>
                                                                </tr>
                                                                <% }) %>
                                                        </tbody>
                                                    </table>
                                                </div>

                                                <div class="d-flex gap-3 mt-4">
                                                    <button type="submit" class="flex-fill"
                                                        style="background: #b91c1c; color: white; border: none; border-radius: 8px; padding: 0.65rem 1rem; font-weight: 600;">
                                                        ⊘ Deactivate Selected
                                                    </button>
                                                    <a href="/admin/dashboard" class="flex-fill text-center"
                                                        style="background: #f1f5f9; color: #334155; border: 1px solid #cbd5e1; border-radius: 8px; padding: 0.65rem 1rem; font-weight: 600; text-decoration: none;">
                                                        ✕ Cancel
                                                    </a>
                                                </div>
                                            </form>
                                            <% } %>

                </div>
            </div>
        </main>

        <%- include('../partials/_footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>