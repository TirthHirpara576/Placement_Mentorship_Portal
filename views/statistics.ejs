<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Statistics – Placement Mentorship Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>

    <% if (typeof isAdmin !=='undefined' && isAdmin) { %>
        <%- include('partials/_navbar_admin', { activePage: activePage, adminName: adminName }) %>
            <% } else if (typeof isCoordinator !=='undefined' && isCoordinator) { %>
                <%- include('partials/_navbar_coord', { activePage: activePage, coordName: coordName }) %>
                    <% } else { %>
                        <%- include('partials/_navbar') %>
                            <% } %>

                                <main class="section-wrapper"
                                    style="background-color: #f1f5f9; min-height: calc(100vh - 70px); padding-top: 2rem;">
                                    <div class="container">
                                        <h1 class="page-title text-center mb-4"
                                            style="color: #1e293b; font-weight: 700; display: flex; align-items: center; justify-content: center; gap: 10px;">
                                            🔍 Placement Deep-Dive
                                        </h1>

                                        <!-- Filter Section -->
                                        <div class="card mb-4"
                                            style="border: none; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
                                            <div class="card-body p-4">
                                                <form method="GET" action="/statistics" class="row g-3 align-items-end">
                                                    <div class="col-md-5">
                                                        <label for="bid" class="form-label"
                                                            style="font-weight: 600; font-size: 0.9rem; color: #475569;">Branch</label>
                                                        <select name="bid" id="bid" class="form-select"
                                                            style="background-color: #f8fafc; border: 1px solid #cbd5e1;">
                                                            <option value="">-- All Branches --</option>
                                                            <% branches.forEach(b=> { %>
                                                                <option value="<%= b.bid %>" <%=selectedBid==b.bid
                                                                    ? 'selected' : '' %>><%= b.bname %>
                                                                </option>
                                                                <% }) %>
                                                        </select>
                                                    </div>
                                                    <div class="col-md-5">
                                                        <label for="yid" class="form-label"
                                                            style="font-weight: 600; font-size: 0.9rem; color: #475569;">Year</label>
                                                        <select name="yid" id="yid" class="form-select"
                                                            style="background-color: #f8fafc; border: 1px solid #cbd5e1;">
                                                            <option value="">-- All Years --</option>
                                                            <% years.forEach(y=> { %>
                                                                <option value="<%= y.yid %>" <%=selectedYid==y.yid
                                                                    ? 'selected' : '' %>><%= y.year %>
                                                                </option>
                                                                <% }) %>
                                                        </select>
                                                    </div>
                                                    <div class="col-md-2">
                                                        <button type="submit" class="btn w-100"
                                                            style="background-color: #1e3a8a; color: white; border-radius: 8px; font-weight: 600; padding: 0.6rem;">
                                                            Analyze
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>

                                        <!-- Summary Cards -->
                                        <div class="row g-3 mb-4">
                                            <div class="col-md-4">
                                                <div class="card text-center h-100"
                                                    style="background-color: #0263b8; color: white; border: none; border-radius: 12px; box-shadow: 0 4px 10px rgba(2,99,184,0.3);">
                                                    <div
                                                        class="card-body d-flex flex-column justify-content-center py-4">
                                                        <h6 class="text-uppercase mb-2"
                                                            style="font-size: 0.8rem; letter-spacing: 1px; font-weight: 700;">
                                                            Total Placed</h6>
                                                        <h2 class="mb-0" style="font-weight: 800; font-size: 2.2rem;">
                                                            <%= totalPlaced %>
                                                        </h2>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="card text-center h-100"
                                                    style="background-color: #216e39; color: white; border: none; border-radius: 12px; box-shadow: 0 4px 10px rgba(33,110,57,0.3);">
                                                    <div
                                                        class="card-body d-flex flex-column justify-content-center py-4">
                                                        <h6 class="text-uppercase mb-2"
                                                            style="font-size: 0.8rem; letter-spacing: 1px; font-weight: 700;">
                                                            Highest Package</h6>
                                                        <h2 class="mb-0" style="font-weight: 800; font-size: 2.2rem;">
                                                            <%= highestPackage %> <span
                                                                    style="font-size: 1.2rem;">LPA</span>
                                                        </h2>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="card text-center h-100"
                                                    style="background-color: #0891b2; color: white; border: none; border-radius: 12px; box-shadow: 0 4px 10px rgba(8,145,178,0.3);">
                                                    <div
                                                        class="card-body d-flex flex-column justify-content-center py-4">
                                                        <h6 class="text-uppercase mb-2"
                                                            style="font-size: 0.8rem; letter-spacing: 1px; font-weight: 700;">
                                                            Average Package</h6>
                                                        <h2 class="mb-0" style="font-weight: 800; font-size: 2.2rem;">
                                                            <%= avgPackage %> <span
                                                                    style="font-size: 1.2rem;">LPA</span>
                                                        </h2>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Chart Section -->
                                        <div class="card mb-5"
                                            style="border: none; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
                                            <div class="card-body p-4">
                                                <h5 class="text-center mb-4" style="font-weight: 600; color: #334155;">
                                                    Company Recruitment Breakdown</h5>
                                                <div style="position: relative; height: 50vh; width: 100%;">
                                                    <canvas id="companyChart"></canvas>
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </main>

                                <%- include('partials/_footer') %>

                                    <script
                                        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
                                    <script>
                                        const rawData = <% - JSON.stringify(companyRecruitment) %>;

                                        const labels = rawData.map(d => d.cname);
                                        const data = rawData.map(d => parseInt(d.count));

                                        const ctx = document.getElementById('companyChart').getContext('2d');
                                        new Chart(ctx, {
                                            type: 'bar',
                                            data: {
                                                labels: labels,
                                                datasets: [{
                                                    label: 'Number of Students',
                                                    data: data,
                                                    backgroundColor: '#3b82f6',
                                                    borderRadius: 4,
                                                    barPercentage: 0.6,
                                                    categoryPercentage: 0.8
                                                }]
                                            },
                                            options: {
                                                responsive: true,
                                                maintainAspectRatio: false,
                                                indexAxis: 'y', // Highcharts horizontal bar chart effect
                                                plugins: {
                                                    legend: { display: false }
                                                },
                                                scales: {
                                                    x: {
                                                        beginAtZero: true,
                                                        ticks: { stepSize: 1 },
                                                        title: { display: true, text: 'Number of Students', font: { size: 12 } }
                                                    },
                                                    y: {
                                                        ticks: { font: { size: 12, family: 'sans-serif' } },
                                                        grid: { display: false }
                                                    }
                                                }
                                            }
                                        });
                                    </script>
</body>

</html>