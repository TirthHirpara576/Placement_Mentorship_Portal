<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Placement Mentorship Portal – Companies</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <% if (typeof isAdmin !=='undefined' && isAdmin) { %>
        <%- include('partials/_navbar_admin', { activePage: activePage, adminName: adminName }) %>
            <% } else if (typeof isCoordinator !=='undefined' && isCoordinator) { %>
                <%- include('partials/_navbar_coord', { activePage: activePage, coordName: coordName }) %>
                    <% } else { %>
                        <%- include('partials/_navbar') %>
                            <% } %>

                                <main class="section-wrapper">
                                    <div class="container">
                                        <h1 class="page-title">Companies</h1>

                                        <!-- Filter Card -->
                                        <form method="GET" action="/">
                                            <div class="filter-card">
                                                <div class="row g-3 align-items-end">
                                                    <div class="col-md-4">
                                                        <label>Select Branch</label>
                                                        <select name="bid" class="form-select">
                                                            <option value="">All Branches</option>
                                                            <% branches.forEach(b=> { %>
                                                                <option value="<%= b.bid %>" <%=selectedBid==b.bid
                                                                    ? 'selected' : '' %>>
                                                                    <%= b.bname %>
                                                                </option>
                                                                <% }) %>
                                                        </select>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label>Select Year</label>
                                                        <select name="yid" class="form-select">
                                                            <option value="">All Years</option>
                                                            <% years.forEach(y=> { %>
                                                                <option value="<%= y.yid %>" <%=selectedYid==y.yid
                                                                    ? 'selected' : '' %>>
                                                                    <%= y.year %>
                                                                </option>
                                                                <% }) %>
                                                        </select>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label>&nbsp;</label>
                                                        <button type="submit" class="btn-filter">Apply Filter</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </form>

                                        <!-- Company Grid -->
                                        <% if (companies.length===0) { %>
                                            <div class="no-data">No companies found for the selected filters.</div>
                                            <% } else { %>
                                                <div class="row g-3">
                                                    <% companies.forEach(c=> { %>
                                                        <div class="col-6 col-md-4 col-lg-3">
                                                            <a href="/Home/CompanyProfile/<%= c.cid %>"
                                                                class="company-card">
                                                                <% if (c.logo) { %>
                                                                    <img src="/logos/<%= c.logo %>"
                                                                        alt="<%= c.cname %> logo">
                                                                    <% } else { %>
                                                                        <div
                                                                            style="height:100px;display:flex;align-items:center;justify-content:center;font-size:2rem;color:#c4b5fd;">
                                                                            🏢</div>
                                                                        <% } %>
                                                                            <span class="cname">
                                                                                <%= c.cname %>
                                                                            </span>
                                                            </a>
                                                        </div>
                                                        <% }) %>
                                                </div>
                                                <% } %>
                                    </div>
                                </main>

                                <%- include('partials/_footer') %>

                                    <script
                                        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>