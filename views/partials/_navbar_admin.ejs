<!-- Admin Panel Sidebar -->
<div id="adminPanel" class="coord-panel">
    <div class="coord-panel-header">
        <span>&#128196; Admin Panel</span>
        <button onclick="toggleAdminPanel()" class="panel-close-btn">&times;</button>
    </div>
    <ul class="coord-panel-links">
        <li><a href="/admin/add-year">Add Year</a></li>
        <li><a href="/admin/add-branch">Add Branch</a></li>
        <li><a href="/admin/add-student-count">Add Students Count</a></li>
        <li><a href="/admin/deactivate-coordinators">Deactivate Coordinators</a></li>
        <li><a href="/admin/add-coordinator">Add New Coordinator</a></li>
        <li><a href="/admin/add-students">Add Students</a></li>
        <li><a href="/admin/remove-students">Remove Students</a></li>
        <li><a href="/admin/send-email">Send Email</a></li>
        <li><a href="/admin/profile">Profile</a></li>
    </ul>
</div>
<div id="adminPanelOverlay" class="panel-overlay" onclick="toggleAdminPanel()"></div>

<script>
    function toggleAdminPanel() {
        const panel = document.getElementById('adminPanel');
        const overlay = document.getElementById('adminPanelOverlay');
        panel.classList.toggle('open');
        overlay.classList.toggle('show');
    }
</script>